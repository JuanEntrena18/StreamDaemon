{
  "name": "streamforger",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w packages/backend\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc -b packages/*"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
