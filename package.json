{
  "name": "streamforger",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc -b packages/*"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
