{
  "name": "@streamforger/desktop",
  "version": "0.2.0",
  "description": "StreamForger — Open-source stream tools, forged for creators",
  "author": "Cyber Haute Couture",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && npm run build:preload && wait-on http://localhost:5173 && electron .",
    "build": "tsc && npm run build:preload",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').renameSync('dist/preload.js', 'dist/preload.cjs')\"",
    "dist": "npm run build --prefix ../frontend && npm run build --prefix ../backend && npx prisma generate --schema=prisma/schema.prisma && npm run build && electron-builder --win --x64",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@streamforger/backend": "*",
    "@streamforger/shared": "*",
    "electron-store": "^8.2.0",
    "better-sqlite3": "^11.0.0",
    "@prisma/client": "^5.10.0",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0",
    "@types/better-sqlite3": "^7.6.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.streamforger.app",
    "productName": "StreamForger",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "dist-electron",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "prisma/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/.env",
        "to": "backend.env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
