generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  twitchId     String   @unique
  login        String
  displayName  String
  avatarUrl    String?
  accessToken  String
  refreshToken String
  tokenExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channelConfig     ChannelConfig?
  giveaways         Giveaway[]
  predictions       Prediction[]
  securityConfig    SecurityConfig?
  securityWhitelist SecurityWhitelist[]
  streamSessions    StreamSession[]
  gameStats         GameStat[]
}

model ChannelConfig {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id])

  activeGame   String?
  overlaySettings String? @default("{}")
  socialLinks  String? @default("[]")
}

model Giveaway {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prize     String
  status    String   @default("pending")
  entries   String   @default("[]")
  winnerId  String?
  createdAt DateTime @default(now())
  endedAt   DateTime?
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  options   String
  status    String   @default("active")
  outcome   String?
  createdAt DateTime @default(now())
  endedAt   DateTime?
}

model SecurityConfig {
  id                  String @id @default(cuid())
  userId              String @unique
  user                User   @relation(fields: [userId], references: [id])
  followBotProtection Boolean @default(true)
  spamFilter          Boolean @default(true)
  autoBan             Boolean @default(true)
  accountAgeFilter    Int    @default(0) // Minimum account age in hours to allow follow
}

model SecurityWhitelist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  username  String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([userId, username])
}

model StreamSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  streamId        String?
  gameName        String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  viewersMax      Int       @default(0)
  followersGained Int       @default(0)
  durationSeconds Int       @default(0)
}

model GameStat {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  gameName        String
  boxArtUrl       String?
  streamCount     Int      @default(0)
  totalViews      Int      @default(0)
  avgViewers      Int      @default(0)
  maxViewers      Int      @default(0)
  followersGained Int      @default(0)
  avgDuration     Int      @default(0)
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([userId, gameName])
}
